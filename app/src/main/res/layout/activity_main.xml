<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CONTEÚDO PRINCIPAL -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F5F7FB">

        <!-- TOOLBAR 2.0 -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_toolbar_gradient"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="14dp"
            android:elevation="6dp">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtToolbarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="📖 Bíblia IBSCC"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- CONTAINER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- INÍCIO -->
            <FrameLayout
                android:id="@+id/layoutInicio"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible" />

            <!-- BÍBLIA -->
            <LinearLayout
                android:id="@+id/layoutBiblia"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp"
                    app:strokeColor="#E3E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚 Livros da Bíblia"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1E293B" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Escolha um livro para começar sua leitura"
                            android:textSize="14sp"
                            android:textColor="#64748B" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <ListView
                    android:id="@+id/listLivros"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/white"
                    android:divider="#EEF2F7"
                    android:dividerHeight="1dp" />

            </LinearLayout>

            <!-- BUSCA -->
            <LinearLayout
                android:id="@+id/layoutBuscar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp"
                    app:strokeColor="#E3E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔎 Buscar na Bíblia"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1E293B" />

                        <EditText
                            android:id="@+id/edtBusca"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/bg_edittext_modern"
                            android:hint="Digite palavra, frase ou referência"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/btnPesquisar"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_button_moderno"
                            android:text="Pesquisar"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <ListView
                    android:id="@+id/listResultados"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/white"
                    android:divider="#EEF2F7"
                    android:dividerHeight="1dp" />

            </LinearLayout>

            <!-- FAVORITOS -->
            <LinearLayout
                android:id="@+id/layoutFavoritos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp"
                    app:strokeColor="#E3E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Seus Favoritos"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1E293B" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Versículos salvos por você"
                            android:textSize="14sp"
                            android:textColor="#64748B" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <ListView
                    android:id="@+id/listFavoritos"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/white"
                    android:divider="#EEF2F7"
                    android:dividerHeight="1dp" />

            </LinearLayout>

            <!-- VERSÍCULO DO DIA -->
            <LinearLayout
                android:id="@+id/layoutVersiculoDia"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:background="@drawable/bg_versiculo_card">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌅 Versículo do Dia"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@android:color/white" />

                        <TextView
                            android:id="@+id/txtVersiculoDia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Carregando..."
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="italic"
                            android:gravity="center"
                            android:lineSpacingMultiplier="1.4" />

                        <TextView
                            android:id="@+id/txtReferenciaDia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="— Referência"
                            android:textColor="#E2E8F0"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnCompartilharDia"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/bg_button_light"
                            android:text="📤 Compartilhar"
                            android:textAllCaps="false"
                            android:textColor="#1E3A8A"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- PROGRAMAÇÃO -->
            <FrameLayout
                android:id="@+id/layoutProgramacao"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>